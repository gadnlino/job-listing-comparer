# Optional: Adzuna job source (register at https://developer.adzuna.com/)
# ADZUNA_APP_ID=
# ADZUNA_APP_KEY=

# LLM executive summary — Groq recommended for cloud deploy (https://console.groq.com)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=

# Local LLM alternatives (docker-compose llama or Ollama)
# LLM_BASE_URL=http://localhost:8080
# LLM_MODEL=default
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# PDF output: weasyprint (local server PDF), browser (client auto-download), off
PDF_RENDERER=weasyprint

# Railway / lightweight cloud profile (example):
# PDF_RENDERER=browser
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_...
# LINK_VALIDATION_ENABLED=false
# LINK_VALIDATION_MAX_JOBS=25

# Link validation (defaults shown)
# LINK_VALIDATION_ENABLED=true
# LINK_VALIDATION_MAX_JOBS=200
# LINK_VALIDATION_TIMEOUT_SECONDS=10
# LINK_VALIDATION_MIN_BODY_BYTES=500
